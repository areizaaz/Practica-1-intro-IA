# ============================================================
# INSTANCIAS — Trabajo
# ============================================================

ex:trabajoAdmin a ex:Trabajo ;
    rdfs:label                 "Administrativo de Oficina" ;
    ex:tieneIndiceRiesgoLaboral 5 .

ex:trabajoVentas a ex:Trabajo ;
